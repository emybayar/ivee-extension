{
  "manifest_version": 3,
  "name": "ivee Prompt Improver",
  "version": "1.0.0",
  "description": "Highlight your prompt on ChatGPT, Claude, Gemini, or Perplexity and instantly improve it with ivee.",
  "homepage_url": "https://ivee.jobs",

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://ivee-ext-backend.vercel.app"
  },

  "permissions": ["activeTab"],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://ivee-ext-backend.vercel.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ivee Prompt Improver",
    "default_icon": {
      "16": "icons/ivee-icon16.png",
      "20": "icons/ivee-icon-20.png",
      "48": "icons/ivee-icon48.png",
      "128": "icons/ivee-icon128.png"
    }
  },

  "icons": {
    "16": "icons/ivee-icon16.png",
    "20": "icons/ivee-icon-20.png",
    "48": "icons/ivee-icon48.png",
    "128": "icons/ivee-icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["font/*", "icons/*"],
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*"
      ]
    }
  ]
}
